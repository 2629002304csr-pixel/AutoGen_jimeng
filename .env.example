# 复制成 .env 并填入你的 key（**只**作 docker-compose 里的服务器 fallback 用）
# cp .env.example .env
#
# ⚠️ 注意：这个文件仅供服务器"自用"或"无人填 key 时"作 fallback
# 真正使用时请让每个用户在浏览器 ⚙️ 设置里填自己的 key（存到浏览器 localStorage）
# 这样做的好处：
#   1. API key 不进服务器文件系统
#   2. 每个用户用自己的 key、用量独立计费
#   3. 你不背泄漏责任

# DeepSeek（国内便宜，推荐）
# 注册: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# OpenAI（官方端点）
OPENAI_API_KEY=

# Qwen / 通义千问（阿里 DashScope）
# 注册: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# M27.2：本机 Docker on WSL2/严格 NAT/公司代理遇 RemoteProtocolError 时
# 设为 1 强制非流式 —— 牺牲 UI 实时刷新，但流式 chunk 不再被中间链路掐断
# Railway / Render / VPS 默认 0 即可
JIMENG_DISABLE_STREAM=0
